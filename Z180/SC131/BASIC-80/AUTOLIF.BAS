10 REM *** 2D RANDOM LIFE FOR MBASIC 5.21 ***
20 DIM A(24,70), B(24,70)
30 REM --- MBASIC SEED GENERATOR ---
40 PRINT "TYPE A RANDOM NUMBER (1-32767) TO SEED GAME:";
50 INPUT S: X=RND(-S)
60 REM --- CLEAR SCREEN VIA SCROLLING ---
70 FOR I=1 TO 30: PRINT: NEXT I
80 REM --- GENERATE THE RANDOM COLONY ---
90 FOR X=1 TO 22: FOR Y=1 TO 68
100 IF RND(1) > .65 THEN A(X,Y)=1 ELSE A(X,Y)=0
110 NEXT Y: NEXT X
120 G=0
130 REM --- MAIN EMULATION LOOP ---
140 G=G+1: P=0
150 PRINT: PRINT "GENERATION:"; G
160 FOR X=1 TO 22
170 PRINT
180 FOR Y=1 TO 68
190 IF A(X,Y)=1 THEN PRINT "*";: P=P+1 ELSE PRINT " ";
200 REM --- SUM 8 NEIGHBORS ---
210 C=A(X-1,Y-1)+A(X-1,Y)+A(X-1,Y+1)+A(X,Y-1)+A(X,Y+1)+A(X+1,Y-1)+A(X+1,Y)+A(X+1
,Y+1)
220 REM --- CONWAY'S LIFE LAWS ---
230 B(X,Y)=0
240 IF A(X,Y)=1 AND (C=2 OR C=3) THEN B(X,Y)=1
250 IF A(X,Y)=0 AND C=3 THEN B(X,Y)=1
260 NEXT Y: NEXT X
270 REM --- TRANSFER NEW GENERATION ---
280 FOR X=1 TO 22: FOR Y=1 TO 68: A(X,Y)=B(X,Y): NEXT Y: NEXT X
290 REM --- CHECK FOR EXTINCTION ---
300 IF P=0 THEN PRINT "COLONY DIED OUT!": GOTO 40
310 REM --- SLOWDOWN LOOP ---
320 FOR D=1 TO 200: NEXT D
330 GOTO 140
