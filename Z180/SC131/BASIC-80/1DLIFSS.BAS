10 REM *** 1D LIFE SCREENSAVER - 80 COLUMNS ***
20 DIM A(82), B(82)
30 PRINT "TYPE A RANDOM SEED NUMBER (1-32767):";
40 INPUT S: X=RND(-S)
50 REM --- INITIAL FULL SCREEN SEED ---
60 FOR X=1 TO 80
70 IF RND(1) > .5 THEN A(X)=1 ELSE A(X)=0
80 NEXT X
90 REM --- MAIN STREAMING LOOP ---
100 AC=0: REM --- ACTIVE CELL COUNTER ---
110 FOR X=1 TO 80
120 IF A(X)=1 THEN PRINT "*";: AC=AC+1 ELSE PRINT " ";
130 NEXT X
140 PRINT: REM --- FLUSH ROW TO TERMINAL ---
150 REM --- SETUP BOUNDARY WRAP-AROUNDS ---
160 A(0)=A(80): A(81)=A(1)
170 REM --- CALCULATE NEXT GENERATION ---
180 FOR X=1 TO 80
190 L=A(X-1): R=A(X+1)
200 IF L<>R THEN B(X)=1 ELSE B(X)=0
210 NEXT X
220 REM --- SCREENSAVER SAFEGUARD (ANTI-DEATH) ---
230 IF AC=0 OR AC=80 THEN FOR X=1 TO 80: B(X)=INT(RND(1)*2): NEXT X
240 REM --- UPDATE ACTIVE ROWS ---
250 FOR X=1 TO 80: A(X)=B(X): NEXT X
260 REM --- TIMING DELAY LOOP ---
270 FOR D=1 TO 50: NEXT D
280 GOTO 100
