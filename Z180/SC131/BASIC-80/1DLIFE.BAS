10 REM *** 1D RANDOM LIFE FOR BASIC-80 5.21 ***
20 DIM A(80), B(80)
30 PRINT "TYPE A RANDOM NUMBER (1-32767) TO SEED:";
40 INPUT S: X=RND(-S)
50 REM --- SEED THE INITIAL ROW RANDOMLY ---
60 FOR X=1 TO 78
70 IF RND(1) > .5 THEN A(X)=1 ELSE A(X)=0
80 NEXT X
90 REM --- MAIN PRINT AND EVOLUTION LOOP ---
100 G=G+1: PRINT "GENERATION:"; G
110 FOR X=1 TO 78
120 IF A(X)=1 THEN PRINT "*"; ELSE PRINT " ";
130 NEXT X
140 PRINT: REM --- END OF ROW CARRIAGE RETURN ---
150 REM --- CALCULATE NEXT GENERATION (RULE 90) ---
160 FOR X=1 TO 78
170 REM --- CHECK LEFT AND RIGHT NEIGHBORS ---
180 L=A(X-1): R=A(X+1)
190 REM --- EXCLUSIVE OR LOGIC FOR FRACTAL TRIANGLES ---
200 IF L<>R THEN B(X)=1 ELSE B(X)=0
210 NEXT X
220 REM --- TRANSFER NEW STATE TO ACTIVE ROW ---
230 FOR X=1 TO 78: A(X)=B(X): NEXT X
240 REM --- SLOWDOWN LOOP ---
250 FOR D=1 TO 100: NEXT D
260 GOTO 100
