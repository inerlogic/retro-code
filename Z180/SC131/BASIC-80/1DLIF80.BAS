10 REM *** 1D LIFE FOR CP/M 80-COLUMNS ***
20 DIM A(80), B(80)
30 PRINT "TYPE A RANDOM SEED NUMBER (1-32767):";
40 INPUT S: X=RND(-S)
50 REM --- SEED THE 75 PRINTABLE COLUMNS ---
60 FOR X=1 TO 75
70 IF RND(1) > .5 THEN A(X)=1 ELSE A(X)=0
80 NEXT X
90 REM --- MAIN SYSTEM EXECUTION LOOP ---
100 G=G+1
110 REM --- PRINT PADDED NUMBER AND SPACE ---
120 PRINT USING "####"; G;
130 PRINT " ";
140 REM --- PRINT THE 75-CHARACTER GENERATION ---
150 FOR X=1 TO 75
160 IF A(X)=1 THEN PRINT "*"; ELSE PRINT " ";
170 NEXT X
180 PRINT: REM --- CARRIAGE RETURN FOR NEXT LINE ---
190 REM --- CALCULATE NEXT GENERATION ---
200 FOR X=1 TO 75
210 L=A(X-1): R=A(X+1)
220 IF L<>R THEN B(X)=1 ELSE B(X)=0
230 NEXT X
240 REM --- TRANSFER DATA FOR ACTIVE ROW ---
250 FOR X=1 TO 75: A(X)=B(X): NEXT X
260 REM --- SCROLLING DELAY CONTROL ---
270 FOR D=1 TO 100: NEXT D
280 GOTO 100
